generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider  = "prisma-zod-generator"
  output    = "./src/zod"
  skipFiles = ["updateManyAndReturn*.schema.ts", "*ScalarRelationFilter.schema.ts"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Author {
  id            Int      @id @default(autoincrement())
  sourceId      Int?     @unique              // AuthorID z tblAuthors
  firstName     String
  middleName    String?
  lastName      String
  suffix        String?                       // Suffix
  penName       String?                       // PenName
  description   String?                       // Remarks
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  photos        Json?
  personalEmail String?
  workEmail     String?
  clientId      Int?
  Client        Client?       @relation(fields: [clientId], references: [id])
  TitleAuthors  TitleAuthor[]
}

model TitleAuthor {
  titleId   Int
  authorId  Int
  isMain    Boolean @default(false)          // Main
  order     Int     @default(1)              // Lp
  Title     Title   @relation(fields: [titleId],  references: [id], onDelete: Cascade)
  Author    Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([titleId, authorId])
}

model BalanceAdjustment {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Client {
  id                   Int        @id @default(autoincrement())
  sourceId             Int?       @unique // CustID z tblCustomers (do mapowania przy migracji)
  name                 String
  abbreviation         String?    // CustAbb
  email                String?
  phone                String?
  fax                  String?    // DefaultFax
  www                  String?    // DefaultWWW
  createdAt            DateTime   @default(now())
  updatedAt            DateTime
  address              String?    // Address1
  address2             String?    // Address2
  city                 String?
  state                String?    // StateAbb
  postalCode           String?
  country              String?    @default("Polska")
  language             String?    // LangAbb
  legalForm            String?
  nip                  String?    // TaxID
  vatId                String?    // VATID
  regon                String?
  jurisdiction         String?
  status               String?    // A=active, I=inactive
  notes                String?
  bankAccount          String?    // AccountNo
  bankName             String?    // BankName
  bankAddress          String?    // BankAddress
  bankRoutingNo        String?    // RoutingNo
  bankAccountName      String?    // AccountName
  commission           Decimal?   @db.Decimal(18, 2)
  commissionForeign    Decimal?   @db.Decimal(18, 2)
  commissionMaterials  Decimal?   @db.Decimal(18, 2)
  repModeId            Int?       // RepModeID
  parentId             Int?       // ParentCustID
  Parent               Client?    @relation("ClientHierarchy", fields: [parentId], references: [id])
  Children             Client[]   @relation("ClientHierarchy")
  Author               Author[]
  ClientContact        ClientContact[]
  Document             Document[]
  Invoice              Invoice[]
  TaxResidenceCert     TaxResidenceCert[]
  TaxResidenceSend     TaxResidenceSend[]
  Title                Title[]
}

model Contact {
  id              Int                @id @default(autoincrement())
  phoneNumber     String?
  firstName       String
  middleName      String?
  lastName        String
  informal        Int                @default(0)
  fax             String?
  email           String?
  contactPosition String?
  accountant      Int?
  photos          Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  ClientContact   ClientContact[]
  PublisherContact PublisherContact[]
}

model ClientContact {
  id        Int      @id @default(autoincrement())
  contactId Int
  clientId  Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([contactId, clientId])
}

model PublisherContact {
  id          Int       @id @default(autoincrement())
  contactId   Int
  publisherId Int
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  Contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([contactId, publisherId])
}

model Publisher {
  id                   Int      @id @default(autoincrement())
  sourceId             Int?     @unique // CustID z tblCustomers (do mapowania przy migracji)
  name                 String
  abbreviation         String?  // CustAbb
  email                String?
  phone                String?
  fax                  String?  // DefaultFax
  www                  String?  // DefaultWWW
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  address              String?  // Address1
  address2             String?  // Address2
  city                 String?
  state                String?  // StateAbb
  postalCode           String?
  country              String?  @default("Polska")
  language             String?  // LangAbb
  legalForm            String?
  nip                  String?  // TaxID
  vatId                String?  // VATID
  regon                String?
  jurisdiction         String?
  status               String?  // A=active, I=inactive
  notes                String?
  bankAccount          String?  // AccountNo
  bankName             String?  // BankName
  bankAddress          String?  // BankAddress
  bankRoutingNo        String?  // RoutingNo
  bankAccountName      String?  // AccountName
  commission           Decimal? @db.Decimal(18, 2)
  commissionForeign    Decimal? @db.Decimal(18, 2)
  commissionMaterials  Decimal? @db.Decimal(18, 2)
  repModeId            Int?     // RepModeID
  parentId             Int?     // ParentCustID
  Parent               Publisher?        @relation("PublisherHierarchy", fields: [parentId], references: [id])
  Children             Publisher[]       @relation("PublisherHierarchy")
  PublisherContact     PublisherContact[]
  TaxResidenceCert     TaxResidenceCert[]
  TaxResidenceSend     TaxResidenceSend[]
  Title                Title[]
}

// Tytuł (książka/utwór) — właścicielem praw jest Client lub Publisher
model Title {
  id              Int       @id @default(autoincrement())
  sourceId        Int?      @unique              // TitleID z tblTitles
  clientId        Int?                           // CustID → Client (właściciel praw)
  publisherId     Int?                           // CustID → Publisher (właściciel praw)
  title           String                         // tytuł oryginalny
  isbn            String?                        // ISBN (pełny)
  languageCode    String?                        // LangAbb
  classCode       String?                        // ClassCode (klasa tematyczna)
  edition         Int?                           // numer wydania
  pages           Int?                           // NoOfPages
  copyrightYear   String?                        // rok praw
  copyrightOwner  String?                        // CopyrightOwnerDesc
  keywords        String?                        // KeyWords
  volume          Int?                           // TitleVolume
  totalVolumes    Int?                           // NoOfTitleVolumes
  isHit           Boolean   @default(false)     // Hit
  isCollection    Boolean   @default(false)     // Collection
  isCD            Boolean   @default(false)     // CD
  notes           String?                        // Remarks
  dateOfReceipt   DateTime?                      // DateOfReceipt
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  Client       Client?       @relation(fields: [clientId],    references: [id], onDelete: SetNull)
  Publisher    Publisher?    @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  TitleAuthors TitleAuthor[]
}

// Certyfikat rezydencji podatkowej (dla klienta lub wydawcy)
model TaxResidenceCert {
  id          Int       @id @default(autoincrement())
  sourceId    Int?      @unique           // CertID z tblTaxResidenceCertificate
  clientId    Int?                        // właściciel certyfikatu → Client
  publisherId Int?                        // właściciel certyfikatu → Publisher
  validDate   DateTime                    // data ważności
  requestDate DateTime?                   // data złożenia wniosku
  receiveDate DateTime?                   // data otrzymania
  hasCert     Boolean   @default(false)  // czy certyfikat fizycznie jest
  notes       String?                     // uwagi
  fileData    Bytes?                      // plik PDF certyfikatu
  fileName    String?                     // nazwa pliku
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  Client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  Publisher   Publisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  SendLog     TaxResidenceSend[]
}

// Historia wysyłek certyfikatu (do kogo i kiedy)
model TaxResidenceSend {
  id          Int       @id @default(autoincrement())
  certId      Int
  clientId    Int?                        // odbiorca → Client
  publisherId Int?                        // odbiorca → Publisher
  dateSend    DateTime?                   // data wysłania
  sendOrig    Boolean   @default(false)  // wysłano oryginał
  sendCopy    Boolean   @default(false)  // wysłano kopię
  createdAt   DateTime  @default(now())

  Cert      TaxResidenceCert @relation(fields: [certId], references: [id], onDelete: Cascade)
  Client    Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  Publisher Publisher?       @relation(fields: [publisherId], references: [id], onDelete: SetNull)
}

model Document {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      DocStatus @default(DRAFT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  clientId    Int
  Client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          Int      @id @default(autoincrement())
  clientId    Int
  title       String
  issueDate   DateTime
  paymentDate DateTime
  net         Float
  vatPerc     Int
  vat         Float
  gross       Float
  status      String   @default("issued")
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model RolePermissions {
  id             Int      @id @default(autoincrement())
  module         String   @unique
  userAccess     Boolean  @default(false)
  advancedAccess Boolean  @default(false)
  adminAccess    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model DictCountry {
  id          Int      @id @default(autoincrement())
  description String
  code        String   @unique
  tax         Float
  eu          Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictCountry")
}

model DictCurrency {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictCurrency")
}

model DictLanguage {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictLanguage")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  permissions  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  locale       String   @default("pl")
}

enum DocStatus {
  DRAFT
  SIGNED
}

enum Role {
  ADMIN
  USER
  ADVANCED
}
