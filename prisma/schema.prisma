generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider  = "prisma-zod-generator"
  output    = "./src/zod"
  skipFiles = ["updateManyAndReturn*.schema.ts", "*ScalarRelationFilter.schema.ts"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Author {
  id            Int      @id @default(autoincrement())
  sourceId      Int?     @unique              // AuthorID z tblAuthors
  firstName     String
  middleName    String?
  lastName      String
  suffix        String?                       // Suffix
  penName       String?                       // PenName
  description   String?                       // Remarks
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  photos        Json?
  personalEmail String?
  workEmail     String?
  clientId      Int?
  Client        Client?       @relation(fields: [clientId], references: [id])
  TitleAuthors  TitleAuthor[]
}

model TitleAuthor {
  titleId   Int
  authorId  Int
  isMain    Boolean @default(false)          // Main
  order     Int     @default(1)              // Lp
  Title     Title   @relation(fields: [titleId],  references: [id], onDelete: Cascade)
  Author    Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([titleId, authorId])
}

model BalanceAdjustment {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Client {
  id                   Int        @id @default(autoincrement())
  sourceId             Int?       @unique // CustID z tblCustomers (do mapowania przy migracji)
  name                 String
  abbreviation         String?    // CustAbb
  email                String?
  phone                String?
  fax                  String?    // DefaultFax
  www                  String?    // DefaultWWW
  createdAt            DateTime   @default(now())
  updatedAt            DateTime
  address              String?    // Address1
  address2             String?    // Address2
  city                 String?
  state                String?    // StateAbb
  postalCode           String?
  country              String?    @default("Polska")
  language             String?    // LangAbb
  legalForm            String?
  nip                  String?    // TaxID
  vatId                String?    // VATID
  regon                String?
  jurisdiction         String?
  status               String?    // A=active, I=inactive
  notes                String?
  bankAccount          String?    // AccountNo
  bankName             String?    // BankName
  bankAddress          String?    // BankAddress
  bankRoutingNo        String?    // RoutingNo
  bankAccountName      String?    // AccountName
  commission           Decimal?   @db.Decimal(18, 2)
  commissionForeign    Decimal?   @db.Decimal(18, 2)
  commissionMaterials  Decimal?   @db.Decimal(18, 2)
  repModeId            Int?       // RepModeID
  parentId             Int?       // ParentCustID
  Parent               Client?    @relation("ClientHierarchy", fields: [parentId], references: [id])
  Children             Client[]   @relation("ClientHierarchy")
  Author               Author[]
  ClientContact        ClientContact[]
  Invoice              Invoice[]
  TaxResidenceCert     TaxResidenceCert[]
  TaxResidenceSend     TaxResidenceSend[]
  Title                Title[]
  Agreements           Agreement[]        // umowy gdzie klient jest właścicielem praw
}

model Contact {
  id              Int                @id @default(autoincrement())
  phoneNumber     String?
  firstName       String
  middleName      String?
  lastName        String
  informal        Int                @default(0)
  fax             String?
  email           String?
  contactPosition String?
  accountant      Int?
  photos          Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  ClientContact   ClientContact[]
  PublisherContact PublisherContact[]
}

model ClientContact {
  id        Int      @id @default(autoincrement())
  contactId Int
  clientId  Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([contactId, clientId])
}

model PublisherContact {
  id          Int       @id @default(autoincrement())
  contactId   Int
  publisherId Int
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  Contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([contactId, publisherId])
}

model Publisher {
  id                   Int      @id @default(autoincrement())
  sourceId             Int?     @unique // CustID z tblCustomers (do mapowania przy migracji)
  name                 String
  abbreviation         String?  // CustAbb
  email                String?
  phone                String?
  fax                  String?  // DefaultFax
  www                  String?  // DefaultWWW
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  address              String?  // Address1
  address2             String?  // Address2
  city                 String?
  state                String?  // StateAbb
  postalCode           String?
  country              String?  @default("Polska")
  language             String?  // LangAbb
  legalForm            String?
  nip                  String?  // TaxID
  vatId                String?  // VATID
  regon                String?
  jurisdiction         String?
  status               String?  // A=active, I=inactive
  notes                String?
  bankAccount          String?  // AccountNo
  bankName             String?  // BankName
  bankAddress          String?  // BankAddress
  bankRoutingNo        String?  // RoutingNo
  bankAccountName      String?  // AccountName
  commission           Decimal? @db.Decimal(18, 2)
  commissionForeign    Decimal? @db.Decimal(18, 2)
  commissionMaterials  Decimal? @db.Decimal(18, 2)
  repModeId            Int?     // RepModeID
  parentId             Int?     // ParentCustID
  Parent               Publisher?        @relation("PublisherHierarchy", fields: [parentId], references: [id])
  Children             Publisher[]       @relation("PublisherHierarchy")
  PublisherContact     PublisherContact[]
  TaxResidenceCert     TaxResidenceCert[]
  TaxResidenceSend     TaxResidenceSend[]
  Title                Title[]
  Agreements           Agreement[]        // umowy gdzie wydawca kupuje prawa
  Submissions          Submission[]       // wysyłki oryginałów do wydawcy
}

// Tytuł (książka/utwór) — właścicielem praw jest Client lub Publisher
model Title {
  id              Int       @id @default(autoincrement())
  sourceId        Int?      @unique              // TitleID z tblTitles
  clientId        Int?                           // CustID → Client (właściciel praw)
  publisherId     Int?                           // CustID → Publisher (właściciel praw)
  title           String                         // tytuł oryginalny
  isbn            String?                        // ISBN (pełny)
  languageCode    String?                        // LangAbb
  classCode       String?                        // ClassCode (klasa tematyczna)
  edition         Int?                           // numer wydania
  pages           Int?                           // NoOfPages
  copyrightYear   String?                        // rok praw
  copyrightOwner  String?                        // CopyrightOwnerDesc
  keywords        String?                        // KeyWords
  volume          Int?                           // TitleVolume
  totalVolumes    Int?                           // NoOfTitleVolumes
  isHit           Boolean   @default(false)     // Hit
  isCollection    Boolean   @default(false)     // Collection
  isCD            Boolean   @default(false)     // CD
  notes           String?                        // Remarks
  dateOfReceipt   DateTime?                      // DateOfReceipt
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  Client       Client?       @relation(fields: [clientId],    references: [id], onDelete: SetNull)
  Publisher    Publisher?    @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  TitleAuthors TitleAuthor[]
  Agreements   Agreement[]
  Submissions  Submission[]
}

// Certyfikat rezydencji podatkowej (dla klienta lub wydawcy)
model TaxResidenceCert {
  id          Int       @id @default(autoincrement())
  sourceId    Int?      @unique           // CertID z tblTaxResidenceCertificate
  clientId    Int?                        // właściciel certyfikatu → Client
  publisherId Int?                        // właściciel certyfikatu → Publisher
  validDate   DateTime                    // data ważności
  requestDate DateTime?                   // data złożenia wniosku
  receiveDate DateTime?                   // data otrzymania
  hasCert     Boolean   @default(false)  // czy certyfikat fizycznie jest
  notes       String?                     // uwagi
  fileData    Bytes?                      // plik PDF certyfikatu
  fileName    String?                     // nazwa pliku
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  Client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  Publisher   Publisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  SendLog     TaxResidenceSend[]
}

// Historia wysyłek certyfikatu (do kogo i kiedy)
model TaxResidenceSend {
  id          Int       @id @default(autoincrement())
  certId      Int
  clientId    Int?                        // odbiorca → Client
  publisherId Int?                        // odbiorca → Publisher
  dateSend    DateTime?                   // data wysłania
  sendOrig    Boolean   @default(false)  // wysłano oryginał
  sendCopy    Boolean   @default(false)  // wysłano kopię
  createdAt   DateTime  @default(now())

  Cert      TaxResidenceCert @relation(fields: [certId], references: [id], onDelete: Cascade)
  Client    Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  Publisher Publisher?       @relation(fields: [publisherId], references: [id], onDelete: SetNull)
}

model Invoice {
  id          Int      @id @default(autoincrement())
  clientId    Int
  title       String
  issueDate   DateTime
  paymentDate DateTime
  net         Float
  vatPerc     Int
  vat         Float
  gross       Float
  status      String   @default("issued")
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model RolePermissions {
  id             Int      @id @default(autoincrement())
  module         String   @unique
  userAccess     Boolean  @default(false)
  advancedAccess Boolean  @default(false)
  adminAccess    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model DictCountry {
  id          Int      @id @default(autoincrement())
  description String
  code        String   @unique
  tax         Float
  eu          Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictCountry")
}

model DictCurrency {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictCurrency")
}

model DictLanguage {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("DictLanguage")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  permissions  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  locale       String   @default("pl")
}

// ─── Umowy ───────────────────────────────────────────────────────────────────

// Umowa licencyjna (z tblAgreements)
model Agreement {
  id                  Int       @id @default(autoincrement())
  sourceId            Int?      @unique                     // AgrID z tblAgreements

  // Strony umowy
  publisherId         Int?                                  // CustID → Publisher (kupujący prawa)
  clientId            Int?                                  // ClientID → Client (właściciel praw)
  titleId             Int?                                  // TitleID → Title

  // Warunki ogólne
  agrDate             DateTime                              // AgrDate
  validYY             Int?                                  // ValidYY — ważność w latach
  pubTermMM           Int?                                  // PubTermMM — termin publikacji w mies.
  maxCopies           Int?                                  // MaxNoOfCopies
  minCopies           Int?                                  // MinNoOfCopies
  copiesToOwner       Int?                                  // CopiesToOwner
  copiesToGraal       Int?                                  // CopiesToGraal

  // Warunki finansowe
  currencyCode        String?   @db.Char(3)                // CurrID
  commission          Decimal?  @db.Decimal(10, 4)         // Commission (%)
  commissionMaterials Decimal?  @db.Decimal(10, 4)         // CommissionMaterials (%)
  estimatedCopyPrice  Decimal?  @db.Decimal(18, 2)         // EstimatedCopyPrice
  graalShare          Decimal?  @db.Decimal(10, 4)         // GraalShare (%)
  graalRepresent      Boolean   @default(true)             // GraalRepresent

  // Język i terytorium
  languageCode        String?   @db.Char(3)                // LangAbbr
  countryId           Int?                                  // CountryID → dictCountries

  // Lokalna edycja (dane od wydawcy)
  localTitle          String?   @db.VarChar(150)           // LocalTitle
  localIsbn           String?   @db.VarChar(16)            // LocalISBN
  localPubDate        DateTime?                             // LocalPubDate

  // Metadane
  clientReference     String?   @db.VarChar(50)            // ClientReference
  agrDoc              String?   @db.VarChar(250)           // AgrDoc — ścieżka do pliku umowy
  status              String?   @db.Char(1)                // Status: 1=w toku, 2=aktywna, 3=wygasła, 4=zakończona
  remarks             String?   @db.VarChar(1000)          // Remarks
  agentId             Int?                                  // AgentID
  dateMod             DateTime?                             // DateMod
  userMod             String?   @db.VarChar(30)            // UserMod

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  Publisher      Publisher?       @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  Client         Client?          @relation(fields: [clientId],    references: [id], onDelete: SetNull)
  Title          Title?           @relation(fields: [titleId],     references: [id], onDelete: SetNull)
  Rights         AgreementRight[]
  Events         AgreementEvent[]
  Advances       AgreementAdvance[]
  RoyRates       AgreementRoyRate[]
}

// Prawa przyznane w umowie (z tblAgrRights)
model AgreementRight {
  id                   Int     @id @default(autoincrement())
  sourceId             Int?    @unique                      // AgrRightID z tblAgrRights
  agreementId          Int                                  // AgrID
  rightFormId          Int?                                 // RightID → dictRightsForm.RightFormID
  priceTypeId          Int?                                 // PriceTypeID → dictPriceType.PriceTypeID
  royPriceTypeId       Int?                                 // RoyPriceTypeID → dictRoyPriceType
  royAccountIntervalId Int?                                 // RoyAccountIntervalID → dictRoyAccountInterval
  distributionTypeId   Int?                                 // DistID → dictDistributionType

  Agreement  Agreement          @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  RoyRates   AgreementRoyRate[]
}

// Progi stawek royalty dla prawa w umowie (z tblRoyRates)
model AgreementRoyRate {
  id          Int     @id @default(autoincrement())
  agreementId Int                                           // AgrID
  rightId     Int                                           // AgrRightID → AgreementRight
  step        Int                                           // Step — numer progu (1, 2, 3…)
  copiesMax   Int?                                          // CpsMax — max egz. dla progu (0 = bez limitu)
  rate        Decimal @db.Decimal(10, 4)                   // Rate — stawka royalty (%)

  Agreement Agreement      @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  Right     AgreementRight @relation(fields: [rightId],     references: [id], onDelete: Cascade)

  @@unique([rightId, step])
}

// Zdarzenia/workflow umowy (z tblAgrEvents)
model AgreementEvent {
  id          Int       @id @default(autoincrement())
  sourceId    Int?      @unique                             // AgrEventID z tblAgrEvents
  agreementId Int                                          // AgrID
  eventCode   Int                                          // AgrEventCode → dictAgrEvents.AgrEventCode
  eventDate   DateTime?                                    // EventDate
  endDate     DateTime?                                    // EndDate
  noOfCopies  Int?                                         // NoOfCopies
  dateMod     DateTime?
  userMod     String?   @db.VarChar(30)
  createdAt   DateTime  @default(now())

  Agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId, eventDate(sort: Desc), eventCode(sort: Desc)])
}

// Zaliczki i płatności ryczałtowe (z tblAdvance)
model AgreementAdvance {
  id          Int       @id @default(autoincrement())
  sourceId    Int?      @unique                             // AdvID z tblAdvance
  agreementId Int                                          // AgrID
  instalment  Int?                                         // Inst — numer raty
  advTermId   Int?                                         // AdvTermId → dictAdvTerm.AdvTermId
  advTypeId   Int?                                         // AdvTypeId → dictAdvType.AdvTypeId
  amount      Decimal   @db.Decimal(18, 2)                 // Amount
  termDate    DateTime?                                    // AdvTermDate
  royaltyId   Int?                                         // RoyID — powiązanie z rozliczeniem
  createdAt   DateTime  @default(now())

  Agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
}

// ─── Wysyłki oryginałów do wydawców ──────────────────────────────────────────

model Submission {
  id             Int       @id @default(autoincrement())
  sourceId       Int?      @unique                        // SubmID z tblSubmissions
  titleId        Int?                                     // TitleID
  publisherId    Int?                                     // CustID → Publisher
  contactId      Int?                                     // ContactID (raw, bez relacji)
  copyTypeId     Int?                                     // FK → dictCopyType (raw SQL)
  submSentTypeId Int?                                     // FK → dictSubmSentType (raw SQL)
  submDate       DateTime                                 // SubmDate
  sentDate       DateTime?                                // SentDate
  endDate        DateTime?                                // EndDate
  returnDate     DateTime?                                // ReturnDate
  noOfCopies     Int?                                     // NoOfCopies
  trackingNo     String?   @db.VarChar(30)               // TrackingNo
  exclusive      Boolean   @default(false)               // Exclusive
  submNr         Int?                                     // SubmNr
  status         String?   @db.Char(1)                   // Status
  remarks        String?   @db.VarChar(1000)             // Remarks
  userMod        String?   @db.VarChar(30)               // UserMod
  dateMod        DateTime?                                // DateMod
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  Title     Title?     @relation(fields: [titleId],     references: [id], onDelete: SetNull)
  Publisher Publisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  Events    SubmissionEvent[]

  @@index([titleId])
  @@index([publisherId])
  @@index([submDate])
}

model SubmissionEvent {
  id           Int       @id @default(autoincrement())
  sourceId     Int?      @unique                          // SubmEventID z tblSubmEvents
  submissionId Int
  eventCode    Int                                        // EventCode → dictEvents (raw SQL)
  eventDate    DateTime
  noOfCopies   Int?
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  Submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, eventDate(sort: Desc), eventCode(sort: Desc)])
}

enum Role {
  ADMIN
  USER
  ADVANCED
}
